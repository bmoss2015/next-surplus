# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service-role-key>

# Google (service account JSON as a single-line escaped string)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Gmail OAuth2 (for draft creation on a user account)
GMAIL_CREDENTIALS_JSON={"installed":{"client_id":"...",...}}
GMAIL_TOKEN_JSON={"token":"...","refresh_token":"...",...}

# Google Drive root folder ID for evidence packet uploads
GOOGLE_DRIVE_ROOT_FOLDER_ID=<folder-id>

# Pipeline settings
LOG_LEVEL=INFO
ENVIRONMENT=development
