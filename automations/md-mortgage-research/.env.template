# MD Mortgage Research Agent - Environment Variables
# Copy this file to .env and fill in your credentials.
# Never commit .env to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-secret-key

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Found in: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Google OAuth ──────────────────────────────────────────────────────────────
# IMPORTANT: Must be a "Web application" OAuth client (not "Desktop app").
# In Google Cloud Console → APIs & Services → Credentials:
#   - Create OAuth 2.0 Client ID → Type: Web application
#   - Add authorized redirect URI: https://md-mortgage-research-production.up.railway.app/oauth/google/callback
#   - Download the JSON and paste the FULL CONTENTS as a single line below.
#
# The JSON will look like: {"web":{"client_id":"...","client_secret":"...","redirect_uris":[...],...}}
GOOGLE_OAUTH_CREDENTIALS_JSON={"web":{"client_id":"REPLACE_ME","project_id":"REPLACE_ME","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_secret":"REPLACE_ME","redirect_uris":["https://md-mortgage-research-production.up.railway.app/oauth/google/callback"]}}

# The refresh token obtained after completing the OAuth flow once.
# To get it: POST /oauth/google/start → open the URL in your browser → authorize → copy token from callback page.
GOOGLE_REFRESH_TOKEN=your-google-refresh-token-here

# ── Maryland Land Records ─────────────────────────────────────────────────────
# Account credentials for mdlandrec.net
MDLANDREC_EMAIL=your-email@example.com
MDLANDREC_PASSWORD=your-mdlandrec-password
