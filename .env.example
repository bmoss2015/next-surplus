# =============================================================================
# Next Surplus — environment variables
# =============================================================================
# Copy this file to `.env.local` for local development and fill in real values.
# `.env.local` is gitignored. For production, set the same NEXT_PUBLIC_* and
# SUPABASE_SERVICE_ROLE_KEY values in your Vercel project (Settings → Environment
# Variables). The CLI-only block at the bottom is for local Supabase migrations
# and is NOT needed in Vercel.
#
# Where to find the Supabase values: Supabase dashboard → Project Settings → API.
# =============================================================================

# --- Required by the running app (set these in Vercel too) -------------------

# Your Supabase project URL, e.g. https://abcdefghijklmno.supabase.co
# Public (exposed to the browser). Used by the server, browser, and proxy clients.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase "publishable" key (a.k.a. the legacy anon key).
# Public (exposed to the browser). Safe to expose — RLS is what protects data.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY

# Supabase service_role key. SERVER-ONLY SECRET — never expose to the browser.
# Used only for operations that must bypass RLS: sending invite emails
# (auth.admin.inviteUserByEmail) and the one-off setup scripts in scripts/.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Public base URL of the deployed app — no trailing slash.
# Used to build invite links (<SITE_URL>/accept-invite) and password-reset
# links (<SITE_URL>/reset). Local dev: http://localhost:3000. In Vercel: your
# production domain, e.g. https://app.nextsurplus.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Local-only: Supabase CLI (database migrations). NOT needed in Vercel. ----

# Project ref (the subdomain in your Supabase URL). Already in supabase/config.toml;
# duplicated here for convenience with `supabase link` / `supabase db push`.
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# Personal access token for the Supabase CLI — create one at
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=YOUR_SUPABASE_ACCESS_TOKEN

# Your Supabase database password (Project Settings → Database). Used by
# `npx supabase db push --password ...` to apply migrations.
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD
