# Moss Equity Operations Portal — local environment
# Copy this to .env.local and fill in real values.
# .env.local is gitignored.

# Supabase project — get these from the Supabase dashboard:
#   Project URL: Settings → API → Project URL
#   Publishable key: Settings → API → publishable key (or legacy anon key)
#   Service role key: Settings → API → service_role
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Project ref — used by the Supabase CLI for db push, etc.
SUPABASE_PROJECT_REF=

# Public base URL of the app — used to build invite and password-reset links.
# Local dev: http://localhost:3000. In production: your deployed URL (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
